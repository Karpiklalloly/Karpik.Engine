<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <!-- 
        ФИНАЛЬНОЕ РЕШЕНИЕ:
        Этот файл отвечает за обработку динамически загружаемых плагинов (@(PluginReference)).
        Мы используем стандартный механизм ProjectReference, чтобы MSBuild сам разрешил
        и скопировал все зависимости (включая нативные DLL нужной архитектуры).
        <ReferenceOutputAssembly>false</ReferenceOutputAssembly> предотвращает статическую линковку.
    -->
    <ItemGroup Condition="'$(Configuration)' == 'Debug'">
        <ProjectReference Include="@(PluginReference)">
            <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
            <CopyLocal>true</CopyLocal>
        </ProjectReference>
    </ItemGroup>

    <!-- 
        Для RELEASE-сборок мы по-прежнему хотим статическую линковку,
        поэтому мы просто ссылаемся на проекты без каких-либо метаданных.
    -->
    <ItemGroup Condition="'$(Configuration)' != 'Debug'">
        <ProjectReference Include="@(PluginReference)" />
    </ItemGroup>

</Project>
