<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Karpik.Engine.Client.Graphics.Core</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
      <None Update="Pressstart2p.ttf">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
      <None Update="libveldrid-spirv.dll">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </None>
    </ItemGroup>

    <ItemGroup>
      <KarpikModuleDependency Include="Veldrid.SPIRV" />
      <KarpikModuleDependency Include="Veldrid.StartupUtilities" />
      <KarpikModuleDependency Include="Veldrid.Utilities" />
      <KarpikModuleDependency Include="ECS" />
      <KarpikModuleDependency Include="Karpik.Engine.Core.Runner" />
      <KarpikModuleDependency Include="AssetManagement" />
      <KarpikModuleDependency Include="Veldrid" />
      <KarpikModuleDependency Include="Veldrid.SDL2" />
      <KarpikModuleDependency Include="Veldrid.ImGui" />
      <KarpikModuleDependency Include="Window" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="StbImageSharp" Version="2.30.15" />
    </ItemGroup>

</Project>
